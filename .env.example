# ═══════════════════════════════════════════════════════════════════════════════
# ZAYTOUN VISION — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# For demo mode, only VITE_API_BASE and VITE_DEMO_MODE are required.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Frontend Configuration ──────────────────────────────────────────────────

# Base URL for the Azure Functions API
# Local: http://localhost:7071
# Production: https://your-function-app.azurewebsites.net
VITE_API_BASE=http://localhost:7071

# Enable demo mode (uses mock data, no Azure services required)
# Set to "true" for hackathon demos or local development without Azure
VITE_DEMO_MODE=true

# ─── Azure Custom Vision ─────────────────────────────────────────────────────
# Get these from: Azure Portal → Custom Vision → Keys and Endpoint

AZURE_CUSTOM_VISION_ENDPOINT=https://your-region.api.cognitive.microsoft.com
AZURE_CUSTOM_VISION_KEY=your-prediction-key-here
AZURE_CUSTOM_VISION_PROJECT_ID=your-project-guid-here
AZURE_CUSTOM_VISION_ITERATION=Iteration1

# ─── Azure Cosmos DB ──────────────────────────────────────────────────────────
# Get these from: Azure Portal → Cosmos DB → Keys

AZURE_COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your-key-here;
AZURE_COSMOS_DATABASE=zaytoun-vision

# ─── Azure Blob Storage ──────────────────────────────────────────────────────
# Get these from: Azure Portal → Storage Account → Access Keys

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=sample-images

# ─── Azure OpenAI (Optional — for future AI-powered recommendations) ─────────
# Not required for MVP. Planned for v2: natural language analysis reports.

# AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com
# AZURE_OPENAI_KEY=your-openai-key-here
